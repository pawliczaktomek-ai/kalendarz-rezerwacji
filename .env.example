# ═══════════════════════════════════════════════════════════
#  KONFIGURACJA – Kalendarz rezerwacji treningów
#  Skopiuj ten plik jako ".env" i uzupełnij wartości
# ═══════════════════════════════════════════════════════════

# ── Hasło panelu trenera ─────────────────────────────────
ADMIN_PASSWORD=ZmienMnie2024!

# ── Port serwera (domyślnie 3000) ────────────────────────
PORT=3000

# ── Twilio (SMS) ─────────────────────────────────────────
# Zarejestruj się na https://www.twilio.com/try-twilio
# Znajdziesz dane w: Console Dashboard → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+48xxxxxxxxx   # lub numer US: +1xxxxxxxxxx

# Telefon trenera – opcjonalnie, dostanie SMS przy każdej nowej rezerwacji
TRAINER_PHONE=+48600000000

# ── Google Calendar ──────────────────────────────────────
# Jak skonfigurować:
# 1. Wejdź na https://console.cloud.google.com/
# 2. Utwórz projekt → włącz "Google Calendar API"
# 3. Utwórz konto usługi (Service Account) → pobierz klucz JSON
# 4. Zapisz pobrany plik jako "service-account.json" w folderze aplikacji
# 5. W Google Calendar → Ustawienia kalendarza → Udostępnianie:
#    dodaj e-mail konta usługi z uprawnieniami "Wprowadzanie zmian"
GOOGLE_CALENDAR_ID=primary
# Lub wklej ID konkretnego kalendarza, np.: abc123@group.calendar.google.com
